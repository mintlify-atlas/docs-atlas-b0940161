  "keyFeatures": [
    "Hexagonal Architecture with clear separation of concerns",
    "Command Pattern implementation for station-specific task execution",
    "Automatic order decomposition into station tasks (Bar, Hot Kitchen, Cold Kitchen)",
    "RESTful API for order processing and status tracking",
    "SOLID principles and TDD approach with comprehensive test coverage",
    "Docker containerization with multi-stage builds",
    "Spring Boot 3.2 with JPA persistence"
  ],
  "publicApiSurface": [
    "POST /api/orders - Create and process a new order",
    "GET /api/orders/{orderId}/status - Get order status",
    "GET /api/tasks - Get all tasks",
    "GET /api/tasks/station/{station} - Get tasks by station",
    "POST /api/tasks/{taskId}/start - Start task preparation",
    "ProcessOrderPort - Process order use case interface",
    "GetOrderStatusPort - Get order status use case interface",
    "GetTasksByStationPort - Get tasks by station use case interface",
    "StartTaskPreparationPort - Start task preparation use case interface"
  ]
}
